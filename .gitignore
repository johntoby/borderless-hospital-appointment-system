# =============================================================
# .gitignore — Exclude Docker config files (student exercise)
# =============================================================
# Students must write these files themselves as part of the exercise.
# Do NOT commit them to the repository.
# =============================================================

# Docker exercise files — students create these
backend/Dockerfile
frontend/Dockerfile
frontend/nginx.conf
docker-compose.yml

# =============================================================
# Standard ignores
# =============================================================

# Java / Maven
backend/target/
*.class
*.jar
*.war

# Node / React
frontend/node_modules/
frontend/build/

# IDE files
.idea/
*.iml
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Environment files (keep .env.development as it's needed)
.env
.env.local
.env.production.local
